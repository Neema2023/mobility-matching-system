{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "./",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,

    "types": ["jest", "node"],

    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src",
    "scripts"
  ]
}